<?xml version="1.0" encoding="UTF-8"?>
<!--
  metadata-complete="true" tells the servlet container to ONLY read this file
  and ignore all annotation scanning / ServletContainerInitializers (including
  Jersey's JerseyServletContainerInitializer). This prevents Jersey from
  auto-registering a SECOND servlet via @ApplicationPath, which would collide
  with the explicit registration below and cause unpredictable routing.
-->
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1"
         metadata-complete="true">

    <display-name>Smart Campus API</display-name>

    <!--
      We register the Jersey servlet and point it at our Application subclass.
      Because metadata-complete="true" is set, Jersey's SCI is disabled and
      @ApplicationPath is NOT processed automatically. The url-pattern below
      acts as the single, authoritative base path for all API routes.
      All @Path annotations in resource classes are relative to /api/v1.
    -->
    <servlet>
        <servlet-name>jersey-servlet</servlet-name>
        <servlet-class>org.glassfish.jersey.servlet.ServletContainer</servlet-class>
        <init-param>
            <param-name>javax.ws.rs.Application</param-name>
            <param-value>com.smartcampus.application.SmartCampusApplication</param-value>
        </init-param>
        <load-on-startup>1</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>jersey-servlet</servlet-name>
        <url-pattern>/api/v1/*</url-pattern>
    </servlet-mapping>

</web-app>
